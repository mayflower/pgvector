FROM generate_series(1, 30) i;
CREATE INDEX tqh_final_k_docs_idx ON tqh_final_k_docs
USING turbohybrid (
	embedding vector_cosine_hybrid_ops,
	body_tsv bm25_tsvector_ops
);
