SELECT count(*) AS omitted_final_k_limit_count
FROM (
	SELECT id
	FROM tqh_final_k_docs
	ORDER BY embedding <~> hybrid_query(
		text_query => to_tsquery('english', 'common'),
		dense_k => 0,
		bm25_k => 30
	)
	LIMIT 25
) s;
